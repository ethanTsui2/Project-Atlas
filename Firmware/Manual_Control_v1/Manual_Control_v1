#include <Servo.h>

Servo servo;

// Pin assignments
const int servoPin = 9;
const int potPin = A0;

// Servo angle limits
const int minAngle = 0;
const int maxAngle = 180;

void setup() {
  Serial.begin(9600);
  servo.attach(servoPin);
}

void loop() {

  // Read potentiometer
  int potValue = analogRead(potPin);

  // Convert potentiometer reading to servo angle
  int angle = map(potValue, 0, 1023, minAngle, maxAngle);

  // Move servo
  servo.write(angle);

  // Print values for debugging
  Serial.print("Pot: ");
  Serial.print(potValue);
  Serial.print(" | Angle: ");
  Serial.println(angle);

  delay(20);
}
